{
    "name": "site-apps/contact-widget",
    "description": "Contact widget, popups and social icons for Laravel + Filament",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "illuminate/support": "^11.0",
        "illuminate/routing": "^11.0",
        "illuminate/database": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SiteApps\\ContactWidget\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SiteApps\\ContactWidget\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SiteApps\\ContactWidget\\ContactWidgetServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
